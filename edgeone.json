{
  "$schema": "https://edgeone.ai/schemas/edgeone.json",
  "name": "hello-vibe",
  "build": {
    "command": "pip install -r requirements.txt && mkdocs build",
    "outputDirectory": "site"
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|svg|woff|woff2|ttf|eot|ico))",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
